{%- if product.variants.size > 1 -%}
<div class="eva-combo-3">
  <button
    type="button"
    class="eva-combo-3__btn button"
    id="eva-add-all-{{ product.id }}"
    data-variants="{{ product.variants | map: 'id' | json | escape }}"
  >
    Adicionar Kit Completo ({{ product.variants.size }} aromas)
  </button>
  <p class="eva-combo-3__info">Adicione todas as variações de uma vez no carrinho</p>
</div>
<style>
  .eva-combo-3 { margin: 14px 0; }
  .eva-combo-3__btn {
    width: 100%;
    background: linear-gradient(135deg, #c4357a, #9b2761);
    color: #fff !important;
    border: none;
    padding: 15px 20px;
    font-size: 1.4rem;
    font-weight: 700;
    border-radius: 4px;
    cursor: pointer;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: opacity 0.2s;
  }
  .eva-combo-3__btn:hover:not(:disabled) { opacity: 0.88; }
  .eva-combo-3__btn:disabled { opacity: 0.55; cursor: not-allowed; }
  .eva-combo-3__info {
    font-size: 1.2rem;
    color: var(--color-foreground);
    opacity: 0.65;
    text-align: center;
    margin: 6px 0 0;
  }
</style>
<script>
(function () {
  var btn = document.getElementById('eva-add-all-{{ product.id }}');
  if (!btn) return;
  var variantIds = JSON.parse((btn.getAttribute('data-variants') || '[]').replace(/&quot;/g, '"'));
  var originalText = btn.textContent;

  btn.addEventListener('click', function () {
    if (btn.disabled) return;
    btn.disabled = true;
    btn.textContent = 'Adicionando...';

    var items = variantIds.slice(0, 3).map(function (id) {
      return { id: parseInt(id, 10), quantity: 1 };
    });

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ items: items })
    })
      .then(function (r) {
        if (!r.ok) throw new Error('cart error');
        return r.json();
      })
      .then(function () {
        btn.textContent = '✓ Kit adicionado!';
        var drawer = document.querySelector('cart-drawer');
        if (drawer && typeof drawer.open === 'function') {
          drawer.open();
        } else {
          window.location.href = '/cart';
        }
        if (window.publish && window.PUB_SUB_EVENTS) {
          fetch('/cart.js').then(function(r){return r.json();}).then(function(cart){
            window.publish(window.PUB_SUB_EVENTS.cartUpdate, { cart: cart });
          });
        }
        setTimeout(function () {
          btn.disabled = false;
          btn.textContent = originalText;
        }, 2500);
      })
      .catch(function () {
        btn.disabled = false;
        btn.textContent = originalText;
        alert('Erro ao adicionar ao carrinho. Tente novamente.');
      });
  });
})();
</script>
{%- endif -%}
