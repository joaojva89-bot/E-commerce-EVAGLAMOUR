<div id="eva-popup-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:9999;align-items:center;justify-content:center;">
  <div id="eva-popup-box" style="background:#fff;border-radius:16px;max-width:380px;width:92%;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,0.18);position:relative;font-family:inherit;">
    <div style="background:linear-gradient(135deg,#c4357a,#e8703a);padding:32px 24px 24px;text-align:center;">
      <div style="display:inline-block;background:rgba(255,255,255,0.2);border-radius:50%;width:64px;height:64px;line-height:64px;font-size:2rem;margin-bottom:12px;">🎁</div>
      <div style="background:#fff;color:#c4357a;font-size:1.5rem;font-weight:800;border-radius:8px;padding:4px 18px;display:inline-block;letter-spacing:1px;">5% OFF</div>
    </div>
    <div style="padding:24px 24px 28px;text-align:center;">
      <h2 style="margin:0 0 8px;font-size:1.5rem;font-weight:700;color:#1a1a1a;">Você Ganhou 5% OFF</h2>
      <p style="margin:0 0 20px;color:#555;font-size:1.05rem;line-height:1.5;">Use o cupom abaixo na finalização da sua compra:</p>
      <div style="display:flex;align-items:center;justify-content:center;gap:8px;background:#f5f5f5;border:2px dashed #c4357a;border-radius:8px;padding:12px 16px;">
        <span id="eva-coupon-code" style="font-size:1.4rem;font-weight:800;letter-spacing:2px;color:#c4357a;">EVA5</span>
        <button onclick="navigator.clipboard.writeText('EVA5').then(function(){var b=document.getElementById('eva-copy-btn');b.textContent='Copiado!';setTimeout(function(){b.textContent='COPIAR';},2000);})" id="eva-copy-btn" style="background:#c4357a;color:#fff;border:none;border-radius:6px;padding:6px 14px;font-size:0.85rem;font-weight:700;cursor:pointer;letter-spacing:0.5px;">COPIAR</button>
      </div>
    </div>
    <button onclick="document.getElementById('eva-popup-overlay').style.display='none';" style="position:absolute;top:12px;right:14px;background:rgba(255,255,255,0.25);border:none;color:#fff;font-size:1.3rem;line-height:1;cursor:pointer;border-radius:50%;width:28px;height:28px;">✕</button>
  </div>
</div>
<script>
(function(){
  if(sessionStorage.getItem('eva_popup_visto')) return;
  setTimeout(function(){
    var el = document.getElementById('eva-popup-overlay');
    if(el){ el.style.display='flex'; sessionStorage.setItem('eva_popup_visto','1'); }
  }, 3000);
  document.addEventListener('keydown', function(e){ if(e.key==='Escape'){ var el=document.getElementById('eva-popup-overlay'); if(el) el.style.display='none'; } });
  var overlay = document.getElementById('eva-popup-overlay');
  if(overlay){ overlay.addEventListener('click', function(e){ if(e.target===overlay) overlay.style.display='none'; }); }
})();
</script>