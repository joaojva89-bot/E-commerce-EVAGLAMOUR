{%- comment -%}Eva Glamour Hero Carousel{%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Italiana&family=Inter:wght@300;400;500;600;700&family=Cinzel:wght@400;500;600&family=Montserrat:wght@400;700;800;900&display=swap" rel="stylesheet">
<style>
.eva-carousel-wrap{--eva-pink:#D5006D;--eva-pink-deep:#A50054;--eva-pink-blush:#FCEEF4;--eva-gold:#C9A85C;--eva-gold-light:#E4CB8A;--eva-gold-deep:#9B7E3E;--eva-cream:#FBF7F2;--eva-ink:#1A0D14;--eva-paper:#ffffff}
.eva-carousel{position:relative;width:100%;aspect-ratio:16/5.5;overflow:hidden;background:var(--eva-cream)}
.eva-track{display:flex;width:400%;height:100%;transition:transform .9s cubic-bezier(.7,0,.2,1)}
.eva-slide{width:25%;height:100%;flex-shrink:0;position:relative;overflow:hidden}
.eva-banner{width:100%;height:100%;display:grid;grid-template-columns:1.05fr 1fr;position:relative}
.eva-banner .eva-copy{padding:0 3vw 0 4vw;display:flex;flex-direction:column;justify-content:center;z-index:4;position:relative}
.eva-banner .eva-photo{position:relative;overflow:hidden}
.eva-banner .eva-photo img,.eva-banner .eva-photo svg{width:100%;height:100%;object-fit:cover;display:block}
.eva-b-vizzano .eva-photo img,.eva-b-vizzano .eva-photo svg{object-fit:contain;object-position:center;background:var(--eva-cream)}
.eva-eyebrow{display:inline-flex;align-items:center;gap:10px;font-size:10px;letter-spacing:.34em;text-transform:uppercase;font-weight:600;margin-bottom:14px;width:max-content;font-family:'Inter',sans-serif}
.eva-eyebrow::before{content:'';width:24px;height:1px;background:currentColor;display:inline-block}
.eva-brand-mark{font-family:'Cinzel',serif;letter-spacing:.32em;font-weight:500;text-transform:uppercase}
.eva-headline{font-family:'Cormorant Garamond',serif;font-weight:300;line-height:.92;letter-spacing:-.01em}
.eva-headline em{font-style:italic;font-weight:400}
.eva-sub{font-size:13px;line-height:1.6;margin-top:12px;max-width:36ch;font-weight:400;opacity:.82;font-family:'Inter',sans-serif}
.eva-meta-row{display:flex;gap:20px;margin-top:16px;margin-bottom:18px;align-items:center}
.eva-pill{font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:600;padding:5px 12px;border:1px solid;border-radius:999px;font-family:'Inter',sans-serif}
.eva-cta-row{display:flex;gap:12px;align-items:center;margin-top:6px}
.eva-cta{display:inline-flex;align-items:center;gap:10px;padding:12px 24px;font-size:10px;letter-spacing:.28em;text-transform:uppercase;font-weight:600;text-decoration:none;border:1px solid;cursor:pointer;transition:all .25s ease;background:transparent;white-space:nowrap;font-family:'Inter',sans-serif}
.eva-cta.solid{background:var(--eva-ink);color:var(--eva-cream);border-color:var(--eva-ink)}
.eva-cta.solid:hover{background:var(--eva-pink);border-color:var(--eva-pink)}
.eva-cta.outline:hover{background:var(--eva-ink);color:var(--eva-cream)}
.eva-cta-arrow{display:inline-block;width:12px;height:1px;background:currentColor;position:relative}
.eva-cta-arrow::after{content:'';position:absolute;right:0;top:-3px;width:6px;height:6px;border-right:1px solid currentColor;border-top:1px solid currentColor;transform:rotate(45deg)}
.eva-b-aniversario{background:linear-gradient(115deg,#D5006D 0%,#A50054 55%,#7A003E 100%);color:var(--eva-cream)}
.eva-b-aniversario .eva-copy{padding-right:5vw}
.eva-b-aniversario .eva-eyebrow{color:var(--eva-gold-light)}
.eva-b-aniversario .eva-headline{font-size:clamp(36px,4.8vw,86px);color:var(--eva-cream)}
.eva-b-aniversario .eva-headline .eva-em{font-family:'Italiana',serif;font-weight:400;font-style:normal;color:var(--eva-gold-light);letter-spacing:.02em}
.eva-b-aniversario .eva-dates{display:flex;align-items:baseline;gap:12px;margin-top:14px;color:var(--eva-gold-light);font-family:'Cormorant Garamond',serif}
.eva-b-aniversario .eva-dates .eva-num{font-size:clamp(26px,3.2vw,54px);font-weight:300;line-height:1}
.eva-b-aniversario .eva-dates .eva-div{font-size:clamp(18px,2vw,34px);font-weight:300;color:var(--eva-cream);opacity:.5}
.eva-b-aniversario .eva-dates .eva-dlabel{font-family:'Inter',sans-serif;font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--eva-cream);margin-left:8px;line-height:1.5}
.eva-b-aniversario .eva-cta.solid{background:var(--eva-gold-light);color:#A50054;border-color:var(--eva-gold-light)}
.eva-b-aniversario .eva-cta.solid:hover{background:var(--eva-cream);border-color:var(--eva-cream)}
.eva-b-aniversario .eva-cta.outline{color:var(--eva-cream);border-color:rgba(251,247,242,.4)}
.eva-b-aniversario .eva-cta.outline:hover{background:rgba(251,247,242,.1);color:var(--eva-cream)}
.eva-confetti{position:absolute;inset:0;pointer-events:none;z-index:1;overflow:hidden}
.eva-confetti .c{position:absolute;background:var(--eva-gold-light)}
.eva-confetti .c1{width:60px;height:2px;top:12%;left:38%;transform:rotate(35deg);opacity:.5}
.eva-confetti .c2{width:90px;height:2px;top:22%;left:8%;transform:rotate(-18deg);opacity:.4}
.eva-confetti .c3{width:40px;height:2px;bottom:18%;left:42%;transform:rotate(70deg);opacity:.6}
.eva-confetti .c4{width:70px;height:2px;top:64%;left:6%;transform:rotate(15deg);opacity:.5}
.eva-confetti .c5{width:50px;height:2px;top:8%;right:4%;transform:rotate(-40deg);opacity:.4}
.eva-confetti .dot{width:6px;height:6px;border-radius:50%;background:var(--eva-gold-light);opacity:.7}
.eva-confetti .d1{top:18%;left:50%}
.eva-confetti .d2{top:78%;left:32%;opacity:.5}
.eva-confetti .d3{top:40%;left:2%}
.eva-confetti .d4{top:88%;left:48%;opacity:.4}
.eva-b-aniversario .eva-photo::before{content:'';position:absolute;inset:0;background:linear-gradient(to right,rgba(122,0,62,.55) 0%,rgba(122,0,62,0) 35%);z-index:2;pointer-events:none}
.eva-b-aniversario .eva-photo::after{content:'';position:absolute;top:50%;left:-1px;transform:translateY(-50%);width:2px;height:70%;background:linear-gradient(to bottom,transparent,var(--eva-gold-light),transparent);z-index:3}
.eva-seal{position:absolute;top:6%;right:5%;width:100px;height:100px;z-index:5}
.eva-seal svg{width:100%;height:100%}
.eva-seal-inner{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--eva-gold-light);text-align:center}
.eva-seal-inner .eva-seal-big{font-family:'Italiana',serif;font-size:28px;line-height:1}
.eva-seal-inner .eva-seal-small{font-size:7px;letter-spacing:.28em;text-transform:uppercase;margin-top:4px;color:var(--eva-cream)}
.eva-b-vizzano{background:var(--eva-cream);color:var(--eva-ink)}
.eva-b-vizzano .eva-copy{padding-left:5vw}
.eva-b-vizzano .eva-eyebrow{color:var(--eva-gold-deep)}
.eva-b-vizzano .eva-brand-mark.big{font-size:clamp(16px,1.8vw,30px);letter-spacing:.42em;color:var(--eva-ink);margin-bottom:12px}
.eva-b-vizzano .eva-headline{font-size:clamp(32px,4.2vw,76px);color:var(--eva-ink)}
.eva-b-vizzano .eva-headline em{color:var(--eva-gold-deep)}
.eva-b-vizzano .eva-sub{color:#4a3744}
.eva-b-vizzano .eva-cta.solid:hover{background:var(--eva-gold-deep);border-color:var(--eva-gold-deep)}
.eva-b-vizzano .eva-cta.outline{color:var(--eva-ink);border-color:rgba(26,13,20,.3)}
.eva-chain-deco{position:absolute;top:12%;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--eva-gold) 30%,var(--eva-gold) 70%,transparent);opacity:.5;z-index:1}
.eva-chain-deco.bottom{top:auto;bottom:12%}
.eva-b-vizzano .eva-photo::before{content:'';position:absolute;inset:8% 8% 8% 0;border:1px solid var(--eva-gold);z-index:2;pointer-events:none;opacity:.45}
.eva-b-vizzano .eva-photo::after{content:'NOVA COLEÇÃO';position:absolute;top:50%;left:-38px;transform:rotate(-90deg);transform-origin:center;font-size:9px;letter-spacing:.5em;color:var(--eva-gold-deep);font-weight:600;z-index:3;width:200px;text-align:center;font-family:'Inter',sans-serif}
.eva-b-modare{background:#D5006D;color:#fff;display:block!important;position:relative;overflow:hidden}
.eva-b-modare .yd{position:absolute;border-radius:50%;background:#FFE500;pointer-events:none;z-index:1}
.eva-b-modare .yd1{width:clamp(38px,4.8vw,84px);height:clamp(38px,4.8vw,84px);top:7%;left:28%}
.eva-b-modare .yd2{width:clamp(28px,3.4vw,60px);height:clamp(28px,3.4vw,60px);top:5%;left:44%}
.eva-b-modare .yd3{width:clamp(42px,5.2vw,92px);height:clamp(42px,5.2vw,92px);top:11%;left:58%}
.eva-b-modare .yd4{width:clamp(24px,2.8vw,50px);height:clamp(24px,2.8vw,50px);bottom:8%;left:30%}
.eva-b-modare .yd5{width:clamp(36px,4.4vw,78px);height:clamp(36px,4.4vw,78px);bottom:6%;left:52%}
.eva-b-modare .yd6{width:clamp(20px,2.4vw,42px);height:clamp(20px,2.4vw,42px);top:48%;left:24%}
.eva-b-modare .m-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:4;text-align:center;pointer-events:none}
.eva-b-modare .m-eyebrow{font-family:'Montserrat',sans-serif;font-size:clamp(9px,.8vw,14px);font-weight:800;letter-spacing:.28em;text-transform:uppercase;color:#1A0D14;margin-bottom:clamp(2px,.4vw,6px)}
.eva-b-modare .m-brand{font-family:'Montserrat',sans-serif;font-weight:900;font-size:clamp(52px,8.5vw,150px);line-height:.86;color:#1A0D14;letter-spacing:-.025em;text-transform:lowercase}
.eva-b-modare .m-sub{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(14px,1.4vw,24px);color:#fff;margin-top:clamp(4px,.5vw,8px);font-weight:400;letter-spacing:.12em}
.eva-b-modare .m-cta{margin-top:clamp(10px,1.4vw,22px);display:flex;align-items:center;gap:14px;pointer-events:all}
.eva-b-modare .m-cta::before,.eva-b-modare .m-cta::after{content:'';width:clamp(24px,3vw,52px);height:1px;background:rgba(255,255,255,.5)}
.eva-b-modare .m-cta-label{font-family:'Montserrat',sans-serif;font-weight:800;font-size:clamp(8px,.8vw,13px);letter-spacing:.34em;text-transform:uppercase;color:#fff;text-decoration:none;padding:11px 22px;border:1.5px solid rgba(255,255,255,.7);transition:background .22s,color .22s}
.eva-b-modare .m-cta-label:hover{background:#fff;color:#D5006D}
.eva-b-modare .m-photo{position:absolute;right:-2%;bottom:0;height:105%;z-index:2;pointer-events:none}
.eva-b-modare .m-photo img,.eva-b-modare .m-photo svg{height:100%;width:auto;display:block;object-fit:cover}
.eva-b-modare .m-photo::before{content:'';position:absolute;inset:0;background:linear-gradient(to left,transparent 55%,#D5006D 100%);z-index:3}
.eva-b-modare .m-photo::after{content:'';position:absolute;bottom:0;left:0;right:0;height:30%;background:linear-gradient(to top,#D5006D 0%,transparent 100%);z-index:3}
.eva-b-beirario{background:var(--eva-paper);color:var(--eva-ink);grid-template-columns:1fr 1.05fr}
.eva-b-beirario .eva-photo{order:1}
.eva-b-beirario .eva-copy{order:2;padding:0 4vw 0 3vw}
.eva-b-beirario .eva-eyebrow{color:var(--eva-pink)}
.eva-b-beirario .eva-brand-mark.big{font-size:clamp(16px,1.8vw,30px);letter-spacing:.42em;color:var(--eva-ink);margin-bottom:12px;position:relative;padding-bottom:14px}
.eva-b-beirario .eva-brand-mark.big::after{content:'';position:absolute;left:0;bottom:0;width:48px;height:2px;background:var(--eva-gold)}
.eva-b-beirario .eva-headline{font-size:clamp(30px,4vw,72px);color:var(--eva-ink)}
.eva-b-beirario .eva-headline em{color:var(--eva-pink)}
.eva-b-beirario .eva-sub{color:#4a3744}
.eva-price-tag{display:flex;align-items:baseline;gap:14px;margin-top:14px;margin-bottom:16px}
.eva-price-tag .eva-from{font-size:9px;letter-spacing:.28em;text-transform:uppercase;color:var(--eva-gold-deep);font-weight:600;font-family:'Inter',sans-serif}
.eva-price-tag .eva-val{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,3.2vw,54px);font-weight:400;line-height:1;color:var(--eva-pink)}
.eva-price-tag .eva-val sup{font-size:.5em;margin-right:4px}
.eva-price-tag .eva-install{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:#4a3744;font-weight:500;font-family:'Inter',sans-serif;line-height:1.6}
.eva-b-beirario .eva-cta.solid{background:var(--eva-pink);border-color:var(--eva-pink);color:var(--eva-paper)}
.eva-b-beirario .eva-cta.solid:hover{background:var(--eva-pink-deep);border-color:var(--eva-pink-deep)}
.eva-b-beirario .eva-cta.outline{color:var(--eva-ink);border-color:rgba(26,13,20,.25)}
.eva-b-beirario .eva-photo::before{content:'';position:absolute;inset:0;background:linear-gradient(to left,rgba(255,255,255,.7) 0%,transparent 40%);z-index:2;pointer-events:none}
.eva-nav-arrow{position:absolute;top:50%;transform:translateY(-50%);width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.18);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.35);color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;z-index:30;transition:all .25s ease}
.eva-nav-arrow:hover{background:rgba(255,255,255,.95);color:var(--eva-ink)}
.eva-nav-arrow.prev{left:20px}
.eva-nav-arrow.next{right:20px}
.eva-nav-arrow svg{width:16px;height:16px}
.eva-carousel.light-bg .eva-nav-arrow{background:rgba(26,13,20,.08);border-color:rgba(26,13,20,.18);color:var(--eva-ink)}
.eva-carousel.light-bg .eva-nav-arrow:hover{background:var(--eva-ink);color:var(--eva-cream)}
.eva-dots{position:absolute;bottom:22px;left:50%;transform:translateX(-50%);display:flex;gap:6px;z-index:30;align-items:center}
.eva-dot-btn{display:flex;flex-direction:column;align-items:center;gap:5px;cursor:pointer;border:none;background:transparent;padding:4px 3px;font-family:'Inter',sans-serif}
.eva-dot-btn .bar{width:28px;height:2px;background:rgba(255,255,255,.4);transition:all .4s ease;border-radius:1px}
.eva-dot-btn .lbl{font-size:8px;letter-spacing:.24em;text-transform:uppercase;color:rgba(255,255,255,.6);font-weight:500;transition:color .3s ease}
.eva-dot-btn.active .bar{background:#fff;width:48px}
.eva-dot-btn.active .lbl{color:#fff}
.eva-carousel.light-bg .eva-dot-btn .bar{background:rgba(26,13,20,.2)}
.eva-carousel.light-bg .eva-dot-btn .lbl{color:rgba(26,13,20,.5)}
.eva-carousel.light-bg .eva-dot-btn.active .bar{background:var(--eva-ink)}
.eva-carousel.light-bg .eva-dot-btn.active .lbl{color:var(--eva-ink)}
.eva-counter{position:absolute;bottom:26px;right:28px;z-index:30;font-family:'Cormorant Garamond',serif;color:#fff;font-size:12px;letter-spacing:.08em}
.eva-counter .cur{font-size:28px;font-weight:400;line-height:1}
.eva-counter .sep{opacity:.5;margin:0 5px}
.eva-counter .tot{opacity:.6}
.eva-carousel.light-bg .eva-counter{color:var(--eva-ink)}
.eva-progress{position:absolute;bottom:0;left:0;height:2px;background:rgba(255,255,255,.18);width:100%;z-index:30}
.eva-progress .fill{height:100%;background:var(--eva-gold-light);width:0;transition:width .1s linear}
.eva-carousel.light-bg .eva-progress{background:rgba(26,13,20,.1)}
.eva-carousel.light-bg .eva-progress .fill{background:var(--eva-pink)}
.eva-post-strip{width:100%;background:#fff;padding:16px 40px;display:grid;grid-template-columns:repeat(4,1fr);gap:20px;border-top:1px solid #f0e9e2}
.eva-feature{display:flex;align-items:center;gap:12px;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:#4a3744;font-weight:500;font-family:'Inter',sans-serif}
.eva-feature .ico{width:28px;height:28px;border-radius:50%;background:#FCEEF4;color:#D5006D;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.eva-feature .ico svg{width:14px;height:14px;fill:none;stroke:currentColor;stroke-width:1.6}
.eva-feature strong{display:block;color:#1A0D14;margin-bottom:1px;font-weight:700;font-size:10px}
.eva-feature span{font-size:8px;letter-spacing:.18em;opacity:.7}
@media(max-width:900px){.eva-banner{grid-template-columns:1fr}.eva-banner .eva-photo{display:none}.eva-post-strip{grid-template-columns:1fr 1fr;padding:14px 20px}.eva-carousel{aspect-ratio:4/3}}
@media(max-width:600px){.eva-post-strip{grid-template-columns:1fr}.eva-carousel{aspect-ratio:1/1}.eva-dots{bottom:12px}.eva-counter{bottom:16px;right:14px}}
</style>
<div class="eva-carousel-wrap">
<div class="eva-carousel" id="eva-carousel-{{ section.id }}">
<div class="eva-track" id="eva-track-{{ section.id }}">
