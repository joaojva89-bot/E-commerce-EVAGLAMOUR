{%- comment -%}Eva Glamour Hero Carousel{%- endcomment -%}
<style>
.eva-carousel-wrap{position:relative;width:100%;overflow:hidden}
.eva-carousel{position:relative;width:100%;aspect-ratio:16/5.5;overflow:hidden;background:#1a0a10}
.eva-track{display:flex;height:100%;transition:transform .9s cubic-bezier(.7,0,.2,1)}
.eva-slide{min-width:100%;height:100%;position:relative;overflow:hidden;flex-shrink:0}
.eva-slide picture{width:100%;height:100%;display:block}
.eva-slide-img{width:100%;height:100%;object-fit:cover;display:block}
.eva-slide-overlay{position:absolute;inset:0;display:flex;align-items:flex-end;justify-content:center;padding-bottom:7%;z-index:2}
.eva-fj-cta{display:inline-flex;align-items:center;padding:14px 36px;font-size:10px;letter-spacing:.28em;text-transform:uppercase;font-weight:600;text-decoration:none;background:#c4357a;color:#fdf0f5;border:1px solid #c4357a;transition:background .2s,border-color .2s;font-family:Inter,sans-serif}
.eva-fj-cta:hover{background:#7b2d3e;border-color:#7b2d3e;color:#fdf0f5}
.eva-nav{position:absolute;top:50%;transform:translateY(-50%);z-index:10;background:rgba(255,255,255,.18);border:none;width:48px;height:48px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s;color:#fff}
.eva-nav:hover{background:rgba(255,255,255,.35)}
.eva-nav--prev{left:16px}.eva-nav--next{right:16px}
.eva-dots{position:absolute;bottom:14px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:10}
.eva-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.45);border:none;cursor:pointer;padding:0;transition:background .2s}
.eva-dot.active{background:#fff}
@media(max-width:767px){.eva-carousel{aspect-ratio:3/4}.eva-nav{display:none}}
</style>

<div class="eva-carousel-wrap" id="evc-{{ section.id }}">
  <div class="eva-carousel">
    <div class="eva-track" id="evtrack-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'slide' -%}
          <div class="eva-slide" {{ block.shopify_attributes }}>
            {%- assign dimg = block.settings.desktop_image -%}
            {%- assign mimg = block.settings.mobile_image -%}
            {%- if dimg != blank -%}
              <picture>
                {%- if mimg != blank -%}<source media="(max-width:767px)" srcset="{{ mimg | image_url: width: 800 }} 800w, {{ mimg | image_url: width: 1000 }} 1000w">{%- endif -%}
                <img src="{{ dimg | image_url: width: 1920 }}" srcset="{{ dimg | image_url: width: 800 }} 800w, {{ dimg | image_url: width: 1200 }} 1200w, {{ dimg | image_url: width: 1920 }} 1920w" sizes="100vw" alt="{{ dimg.alt | default: '' }}" class="eva-slide-img" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
              </picture>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <div class="eva-slide-overlay">
                <a href="{{ block.settings.button_link | default: '/collections/botas' }}" class="eva-fj-cta">{{ block.settings.button_label }}</a>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- assign slide_count = section.blocks | where: 'type', 'slide' | size -%}
    {%- if slide_count > 1 -%}
      <button class="eva-nav eva-nav--prev" aria-label="Anterior" onclick="evcNav('{{ section.id }}',-1)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="eva-nav eva-nav--next" aria-label="Proximo" onclick="evcNav('{{ section.id }}',1)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
      <div class="eva-dots" id="evdots-{{ section.id }}">
        {%- for block in section.blocks -%}{%- if block.type == 'slide' -%}<button class="eva-dot{% if forloop.first %} active{% endif %}" onclick="evcGo('{{ section.id }}',{{ forloop.index0 }})" aria-label="Slide {{ forloop.index }}"></button>{%- endif -%}{%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
(function(){
  var id='{{ section.id }}';
  var total={{ section.blocks | where: 'type', 'slide' | size }};
  var cur=0,timer;
  function go(n){cur=(n+total)%total;var t=document.getElementById('evtrack-'+id);if(t)t.style.transform='translateX(-'+cur*100+'%)';var dots=document.querySelectorAll('#evdots-'+id+' .eva-dot');dots.forEach(function(d,i){d.classList.toggle('active',i===cur)});}
  window.evcNav=function(s,d){if(s!==id)return;clearInterval(timer);go(cur+d);start();};
  window.evcGo=function(s,n){if(s!==id)return;clearInterval(timer);go(n);start();};
  function start(){if(total>1)timer=setInterval(function(){go(cur+1);},5000);}
  start();
})();
</script>

{% schema %}
{
  "name": "Eva Hero Carousel",
  "tag": "section",
  "class": "eva-hero-carousel-section",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Imagem Desktop"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Imagem Mobile"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Texto do botao",
          "default": "Confira a nova colecao"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link do botao"
        }
      ]
    }
  ],
  "presets": [{
    "name": "Eva Hero Carousel"
  }]
}
{% endschema %}