<script>
(function(){
var sid={{ section.id | json }};
var carousel=document.getElementById('eva-carousel-'+sid);
var track=document.getElementById('eva-track-'+sid);
var fill=document.getElementById('eva-fill-'+sid);
var cur=document.getElementById('eva-cur-'+sid);
var prevBtn=document.getElementById('eva-prev-'+sid);
var nextBtn=document.getElementById('eva-next-'+sid);
var dotContainer=document.getElementById('eva-dots-'+sid);
if(!carousel||!track)return;
var slides=track.querySelectorAll('.eva-slide');
var dots=dotContainer.querySelectorAll('.eva-dot-btn');
var i=0,total=slides.length,dur=6500,progress=0,last=performance.now(),paused=false;
function go(n){i=(n+total)%total;track.style.transform='translateX('+(-i*25)+'%)';dots.forEach(function(d,k){d.classList.toggle('active',k===i)});cur.textContent=String(i+1).padStart(2,'0');carousel.classList.toggle('light-bg',slides[i].dataset.bg==='light');progress=0;fill.style.width='0%';}
function tick(now){var dt=now-last;last=now;if(!paused){progress+=dt;fill.style.width=Math.min(100,(progress/dur)*100)+'%';if(progress>=dur)go(i+1);}requestAnimationFrame(tick);}
prevBtn.addEventListener('click',function(){go(i-1)});
nextBtn.addEventListener('click',function(){go(i+1)});
dots.forEach(function(d){d.addEventListener('click',function(){go(+d.dataset.i)})});
carousel.addEventListener('mouseenter',function(){paused=true});
carousel.addEventListener('mouseleave',function(){paused=false});
document.addEventListener('keydown',function(e){if(e.key==='ArrowRight')go(i+1);if(e.key==='ArrowLeft')go(i-1)});
var tx=null;
carousel.addEventListener('touchstart',function(e){tx=e.touches[0].clientX},{passive:true});
carousel.addEventListener('touchend',function(e){if(tx==null)return;var dx=e.changedTouches[0].clientX-tx;if(Math.abs(dx)>40)go(dx>0?i-1:i+1);tx=null});
go(0);last=performance.now();requestAnimationFrame(tick);
})();
</script>
