<style>
  .eva-depoimentos {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .eva-depoimentos__header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .eva-depoimentos__title {
    margin: 0 0 0.8rem;
  }
  .eva-depoimentos__subtitle {
    font-size: 1.5rem;
    color: var(--color-foreground-secondary, #666);
    margin: 0;
  }
  .eva-depoimentos__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  @media (max-width: 989px) {
    .eva-depoimentos__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 749px) {
    .eva-depoimentos__grid { grid-template-columns: 1fr; }
  }
  .eva-depoimentos__card {
    border: 1px solid var(--color-border, #e8e8e8);
    border-radius: 0.8rem;
    padding: 2.4rem;
    background: var(--color-background);
  }
  .eva-depoimentos__stars {
    display: flex;
    gap: 0.3rem;
    margin-bottom: 1.2rem;
    color: #f5a623;
  }
  .eva-depoimentos__stars svg {
    width: 1.6rem;
    height: 1.6rem;
    fill: currentColor;
  }
  .eva-depoimentos__text {
    font-size: 1.4rem;
    line-height: 1.7;
    color: var(--color-foreground);
    margin: 0 0 1.6rem;
  }
  .eva-depoimentos__author {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .eva-depoimentos__avatar {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: var(--color-base-accent-1, #f0e6f0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-foreground);
    flex-shrink: 0;
    overflow: hidden;
  }
  .eva-depoimentos__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .eva-depoimentos__name {
    font-size: 1.4rem;
    font-weight: 600;
    margin: 0 0 0.2rem;
  }
  .eva-depoimentos__meta {
    font-size: 1.2rem;
    color: var(--color-foreground-secondary, #888);
    margin: 0;
  }
  .eva-depoimentos__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 1.1rem;
    color: #1da851;
    margin-top: 0.3rem;
  }
  .eva-depoimentos__badge svg {
    width: 1.2rem;
    height: 1.2rem;
    fill: currentColor;
  }
</style>

{%- assign star_svg -%}
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
{%- endassign -%}

<div class="eva-depoimentos page-width">
  <div class="eva-depoimentos__header">
    <h2 class="eva-depoimentos__title h2">{{ section.settings.title }}</h2>
    <p class="eva-depoimentos__subtitle">{{ section.settings.subtitle }}</p>
  </div>

  <div class="eva-depoimentos__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'depoimento' -%}
        <div class="eva-depoimentos__card" {{ block.shopify_attributes }}>
          <div class="eva-depoimentos__stars">
            {{ star_svg }}{{ star_svg }}{{ star_svg }}{{ star_svg }}{{ star_svg }}
          </div>
          <p class="eva-depoimentos__text">"{{ block.settings.texto }}"</p>
          <div class="eva-depoimentos__author">
            <div class="eva-depoimentos__avatar">
              {%- if block.settings.foto != blank -%}
                {{ block.settings.foto | image_url: width: 80 | image_tag: loading: 'lazy', alt: block.settings.nome }}
              {%- else -%}
                {{ block.settings.nome | slice: 0 | upcase }}
              {%- endif -%}
            </div>
            <div>
              <p class="eva-depoimentos__name">{{ block.settings.nome }}</p>
              <p class="eva-depoimentos__meta">{{ block.settings.produto }}</p>
              <span class="eva-depoimentos__badge">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                Compra verificada
              </span>
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Depoimentos",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "depoimento",
      "name": "Depoimento",
      "settings": [
        {
          "type": "textarea",
          "id": "texto",
          "label": "Texto do depoimento",
          "default": "Amei o produto! Chegou rápido e a qualidade é incrível."
        },
        {
          "type": "text",
          "id": "nome",
          "label": "Nome da cliente",
          "default": "Maria S."
        },
        {
          "type": "text",
          "id": "produto",
          "label": "Produto comprado",
          "default": "Sandália Vizzano"
        },
        {
          "type": "image_picker",
          "id": "foto",
          "label": "Foto (opcional)"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "O que nossas clientes dizem"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Mais de 13 anos de clientes satisfeitas"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 52,
      "label": "Espaçamento superior"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 52,
      "label": "Espaçamento inferior"
    }
  ],
  "presets": [
    {
      "name": "Depoimentos",
      "blocks": [
        {
          "type": "depoimento",
          "settings": {
            "texto": "Comprei uma sandália Vizzano e me apaixonei! O acabamento é perfeito e chegou em 2 dias. Já é a terceira vez que compro na Eva Glamour.",
            "nome": "Camila R.",
            "produto": "Sandália Vizzano"
          }
        },
        {
          "type": "depoimento",
          "settings": {
            "texto": "Sempre encontro meu número aqui, o que é difícil porque tenho pé largo. Atendimento pelo WhatsApp foi super rápido quando tive dúvida.",
            "nome": "Fernanda M.",
            "produto": "Tênis Modare"
          }
        },
        {
          "type": "depoimento",
          "settings": {
            "texto": "A troca foi sem burocracia nenhuma. Pedi o tamanho errado e resolveram tudo em menos de uma semana. Recomendo demais!",
            "nome": "Juliana P.",
            "produto": "Scarpin Beira Rio"
          }
        }
      ]
    }
  ]
}
{% endschema %}
